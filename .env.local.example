# ============================================================
# MeowAlert 環境變數範本
# 複製此檔案為 .env.local 並填入實際值
# .env.local 已在 .gitignore 中，不會被 commit
# ============================================================

# ------ Supabase ------
# 從 Supabase Dashboard > Settings > API 取得
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxx...
# 只在 server-side (API routes, Server Actions) 使用，絕不暴露前端
SUPABASE_SERVICE_ROLE_KEY=eyJxxx...

# ------ Google Places API ------
# 只用於動物醫院搜尋 (/api/hospitals)
# 從 Google Cloud Console > API & Services > Credentials 取得
GOOGLE_PLACES_API_KEY=AIzaxxx...

# ------ Web Push (VAPID Keys) ------
# 產生方式: npx web-push generate-vapid-keys
# 或至 https://vapidkeys.com/ 產生
NEXT_PUBLIC_VAPID_PUBLIC_KEY=Bxxx...
VAPID_PRIVATE_KEY=xxx...
VAPID_SUBJECT=mailto:admin@meowalert.com

# ------ App Config ------
# 本機開發用 http://localhost:3000
# 正式環境用 https://meowalert.vercel.app (或你的自訂域名)
NEXT_PUBLIC_APP_URL=http://localhost:3000
# 管理員 Email，逗號分隔，用於檢查 admin 權限
NEXT_PUBLIC_ADMIN_EMAILS=your-email@example.com
